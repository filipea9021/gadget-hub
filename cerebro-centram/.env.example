# ══════════════════════════════════════════════
# CEREBRO CENTRAM - Configuração de Ambiente
# ══════════════════════════════════════════════
# Copie este arquivo para .env e preencha suas chaves
# cp .env.example .env

# ── LLM Provider (escolha um) ──
# Opções: anthropic, openai, ollama
LLM_PROVIDER=anthropic

# ── Anthropic (Claude) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI ──
OPENAI_API_KEY=sk-...

# ── Ollama (local, gratuito) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── GitHub (para deploy automático) ──
GITHUB_TOKEN=ghp_...

# ── Upsampler.com (Processamento de Imagens com IA) ──
UPSAMPLER_API_KEY=up_...

# ── n8n Cloud (Automação de Workflows) ──
N8N_BASE_URL=https://seu-n8n.app.n8n.cloud
N8N_API_KEY=n8n_...

# ── Shopify ──
SHOPIFY_API_KEY=shpat_...
SHOPIFY_STORE_URL=https://sua-loja.myshopify.com

# ── Output ──
OUTPUT_DIR=./output
