# =====================================================
# GADGET HUB — Sistema de Agentes Autônomos
# Configuração de Ambiente
# =====================================================
# 1. Copie este arquivo: copy .env.example .env
# 2. Preencha suas credenciais abaixo
# 3. NUNCA commite .env (já está no .gitignore)
# =====================================================

# =====================================================
# MODO DE OPERAÇÃO
# =====================================================
MODO=semi

# =====================================================
# SHOPIFY API
# =====================================================
SHOPIFY_SHOP_DOMAIN=gadget-hub-72955.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2024-01

# =====================================================
# CJ DROPSHIPPING API
# =====================================================
CJ_API_KEY=
CJ_EMAIL=

# =====================================================
# BLENDER RENDER SERVER
# =====================================================
BLENDER_SERVER_URL=http://localhost:8585
BLENDER_API_KEY=
BLENDER_PORT=8585
MAX_CONCURRENT_JOBS=2

# =====================================================
# DASHBOARD
# =====================================================
DASHBOARD_PORT=3001

# =====================================================
# NOTIFICAÇÕES
# =====================================================
WEBHOOK_URL=
NOTIFICATION_EMAIL=

# =====================================================
# MARKETING
# =====================================================
META_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=

# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=info
